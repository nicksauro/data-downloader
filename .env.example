# =============================================================================
# .env.example — Template de variáveis de ambiente para data-downloader
# Owner: Gage (devops)
#
# USO:
#   1. cp .env.example .env
#   2. Preencher PROFITDLL_KEY/USER/PASS com suas credenciais Nelogica
#   3. NUNCA commitar o .env final (gitignored, mas pre-commit hook bloqueia)
#
# Validação: `python -m data_downloader.cli env-check` (Story 1.7b)
# =============================================================================

# -----------------------------------------------------------------------------
# ProfitDLL — Credenciais Nelogica (OBRIGATÓRIO)
# -----------------------------------------------------------------------------
# Chave de licença fornecida pela Nelogica para acesso à ProfitDLL.
# Formato típico: string alfanumérica longa. Sensível — nunca compartilhe.
PROFITDLL_KEY=

# Usuário ProfitChart (mesmo login da plataforma).
PROFITDLL_USER=

# Senha ProfitChart. Sensível — gerenciada via secret manager em produção.
PROFITDLL_PASS=

# Caminho para o diretório que contém ProfitDLL.dll + companions + .dat files.
# Default assume bootstrap-dll.ps1 já rodou e populou profitdll/DLLs/Win64/.
# Em distribuição .exe (PyInstaller --onedir) este caminho é resolvido em runtime.
PROFITDLL_PATH=./profitdll/DLLs/Win64

# -----------------------------------------------------------------------------
# Storage — Diretórios de dados
# -----------------------------------------------------------------------------
# Diretório raiz onde Sol grava Parquet + SQLite catalog.
# Será criado se não existir. Conteúdo é gitignored.
DATA_DIR=./data

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Nível de log da aplicação. Valores: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Em release: INFO. Em troubleshooting: DEBUG (mas Aria/ADR-010 garante que
# DEBUG não loga dentro do hot path — R21 do MANIFEST.md).
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Tuning de filas (R3/R5 — backpressure)
# -----------------------------------------------------------------------------
# Tamanho da fila entre callback DLL e ingestor thread.
# 10000 trades = ~100ms buffer @ 100k trades/s. Aumentar se Pyro detectar
# pause >100ms em GC/Defender (finding H4). Diminuir reduz memória.
DATA_DOWNLOADER_DLL_QUEUE_SIZE=10000

# Tamanho da fila entre ingestor e writer (Parquet flush).
# 5000 trades por chunk antes de forçar flush. Trade-off: maior = melhor
# compressão Parquet, menor = menos perda em crash.
DATA_DOWNLOADER_WRITE_QUEUE_SIZE=5000

# -----------------------------------------------------------------------------
# Opcional — Override de comportamentos
# -----------------------------------------------------------------------------
# Forçar modo offline (mock DLL) — útil para testes em CI sem credenciais.
# Valores: 0 | 1. Default: 0.
# DATA_DOWNLOADER_MOCK_DLL=0

# Habilitar telemetria de performance (counters/histograms para Pyro analisar).
# Valores: 0 | 1. Default: 0 (release), 1 (dev).
# DATA_DOWNLOADER_TELEMETRY=0
